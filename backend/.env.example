# Application
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=your-secret-key-here
ENCRYPTION_KEY=your-encryption-key-here

# Database
DATABASE_URL=sqlite:///./sounds_good.db

# Redis (optional for development)
REDIS_URL=redis://localhost:6379

# ChromaDB (run server on this port; must differ from FastAPI, usually 8000)
CHROMADB_HOST=localhost
CHROMADB_PORT=8001

# Vector search (optional — sensible defaults are built-in)
# VECTOR_SEARCH_DEFAULT_N=1000
# VECTOR_SEARCH_MAX_DISTANCE=

# Spotify API
SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret
SPOTIFY_REDIRECT_URI=http://localhost:3000/callback

# Groq API
GROQ_API_KEY=your-groq-api-key

# CORS
CORS_ORIGINS=["http://localhost:3000"]
